   (leftx       uint8)
   (lefty       uint8)
   (rightx      uint8)
   (righty      uint8)
   (cam-angle-y float)
   (pad-reserved uint8 6)
   ;; World Sync Fields (Mirrored from local-player-info)
   (money       float)
   (gems        float)
   (skill       float)
   (sync-money  float)
   (sync-gems   float)
   (sync-skill  float)
   (sync-flag   uint32)
