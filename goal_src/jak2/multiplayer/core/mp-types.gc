;; --- Function Implementations ---

(defmacro mp-is-jak? ()
  "Is the local player the Host (Jak)? Handles early load (null pointer) and uninitialized role (-1)."
  `(if (or (not *local-info*) (zero? *local-info*))
       #t
       (or (= (-> *local-info* role) 0) (= (-> *local-info* role) -1))
       )
  )

(defmacro mp-is-daxter? ()
  "Is the local player the Client (Daxter)?"
  `(= (-> *local-info* role) 1)
  )

(defmacro mp-enemy-should-process-damage? (e-proc)
  "Should the local machine process damage/state changes? (Owner OR Remote Event)"
  `(or (mp-enemy-authoritative? ,e-proc) *mp-processing-remote-event*)
  )

(defmacro mp-is-traffic-authoritative? ()
  "Is the local player authoritative over traffic? (Current: Host-only)"
  `(mp-is-jak?)
  )

