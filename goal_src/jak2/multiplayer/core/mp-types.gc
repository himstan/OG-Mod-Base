(define-perm *mp-vehicle-net-id-counter* uint (the uint 32768))
(define-perm *mp-last-local-state-id* uint (the uint 0))
(define *multi-sync-tps* 20)

(define-perm *remote-player-is-dying* symbol #f)
(define-perm *remote-player-is-dead* symbol #f)
(define-perm *mp-local-player-is-respawning* symbol #f)
