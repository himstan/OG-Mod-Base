   (host-continue uint8 32)
   (task-mask   uint8 64)
   (active-task-mask uint8 64)
   (sync-aids-count uint32)
   (sync-aids   uint32 128)
   (pad-align   uint8 12)
   (veh-state   mp-vehicle-state :inline)
   )
  :size-assert 880)

(deftype local-player-info (structure)
  ((x           float)
   (y           float)
   (z           float)
   (angle       float)
   (role        int32)
   (state-id    uint32)
   (level       uint32)
   (packet-id   uint32)
   (riding?     uint32)
   (clock       time-frame)
   (buttons     uint16)
   (leftx       uint8)
   (lefty       uint8)
   (rightx      uint8)
   (righty      uint8)
   (cam-angle-y float)
   (pad-reserved uint8 6)
   ;; Global World Sync (Outgoing)
   (money       float)
   (gems        float)
   (skill       float)
   ;; Global World Sync (Incoming from Host)
   (sync-money  float)
   (sync-gems   float)
   (sync-skill  float)
   (sync-flag   uint32)
   (host-task   uint32)
   (host-node   uint32)
   (host-continue uint8 32)
   (task-mask   uint8 64)
   (active-task-mask uint8 64)
   (sync-aids-count uint32)
   (sync-aids   uint32 128)
   (player-procs handle 2)
   (veh-state   mp-vehicle-state :inline)
   )
  :size-assert 880)
(deftype mp-event-buffer (structure)
  ((out-count uint32)
   (pad1      uint8 12)
   (out-events mp-event 16 :inline)
   (in-count  uint32)
   (pad2      uint8 12)
   (in-events  mp-event 16 :inline)
   )
  :size-assert 15904) ;; (16 + 16*496) * 2 = 15904

(defconstant MP_MAX_SYNC_ENEMIES 128)
(deftype mp-enemy-sync-buffer (structure)
  ((local-count     uint32)
   (local-enemies   mp-enemy-state MP_MAX_SYNC_ENEMIES :inline)
   (remote-count    uint32)
   (remote-enemies  mp-enemy-state MP_MAX_SYNC_ENEMIES :inline)
   (last-sync-time  uint64)
   )
  :size-assert 20520)
;; --- Pedestrian State IDs (for state-based sync, replaces raw animation index) ---
