  (die-falling           42)
  (die-fast              43)
  )

(deftype mp-pedestrian-state (structure)
  ((net-id          uint32)
   (object-type     uint8)
   (object-variance uint8)
   (state-id        uint8)    ;; Replaces anim-index: numeric mp-ped-state-id
   (pad-align       uint8)    ;; Alignment padding (was 2 bytes, now 1 since we use one for state-id)
   (x               float)
   (y               float)
   (z               float)
   (quat-x          float)
   (quat-y          float)
   (quat-z          float)
   (quat-w          float)
   (hp              int32)
   (flags           uint8)
   (target-aid      uint8)    ;; 0 = none, 1 = Host, 2 = Client
   (pad             uint8 22) ;; Reduced from 26 to compensate for target-aid
   )
  :size-assert 64)

(defconstant MP_MAX_SYNC_PEDESTRIANS 128)
(defconstant MP_MAX_SYNC_VEHICLES 64)

(deftype mp-traffic-sync-buffer (structure)
  ((ped-count       uint32)
   (ped-enemies     mp-pedestrian-state MP_MAX_SYNC_PEDESTRIANS :inline)
   (veh-count       uint32)
   (veh-enemies     mp-vehicle-state MP_MAX_SYNC_VEHICLES :inline)
   (last-sync-time  uint64)
   )
  :size-assert 13352)

;; --- Ghost Record for Traffic Sync (Position Prediction) ---
;; Stores the last-known authoritative position/state for each traffic entity.
;; Used by the non-authoritative side's P-controller to smoothly correct local simulation.
(deftype mp-traffic-ghost-record (structure)
  ((net-id          uint32)
   (entity-kind     uint8)       ;; 0=pedestrian, 1=vehicle
   (pad             uint8 3)
   (last-seen       time-frame)  ;; Timestamp of last remote update
   (ghost-trans     vector :inline)
   (ghost-quat      quaternion :inline)
   (ghost-linvel    vector :inline)   ;; Vehicles: last received linear velocity; peds: unused
   (ghost-angvel    vector :inline)   ;; Vehicles: last received angular velocity; peds: unused
   (ghost-hp         int32)
   (ghost-state-id  uint8)           ;; Pedestrian state ID; unused for vehicles
   (ghost-target-aid uint8)          ;; Target sync for pedestrians (e.g. crimson-guard)
   (last-attack-id   uint32)
   (last-local-attack-id uint32)
   (last-local-attack-time time-frame)
   (last-correction-time   uint64)
   )
  )

(defconstant MP_MAX_TRAFFIC_GHOST_RECORDS 192)
(define-perm *mp-traffic-ghosts*
  (inline-array mp-traffic-ghost-record)
  (new 'static 'inline-array mp-traffic-ghost-record 192))

