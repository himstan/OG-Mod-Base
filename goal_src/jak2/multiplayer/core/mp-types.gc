(deftype mp-enemy-auth-record (structure)
  ((aid                uint32)
   (owner              uint8)
   (is-aggro           symbol)
   (last-transfer-time time-frame)
   (last-remote-seen   time-frame)
   (last-attack-id     uint32)
   (last-local-attack-id uint32)
   (last-local-attack-time time-frame)
   ;; --- Ghost Predictive Sync ---
   (ghost-trans        vector :inline)
   (ghost-quat         quaternion :inline)
   (ghost-state        mp-enemy-state-id)
   (ghost-focus-aid    uint32)
   (just-taken-authority symbol)
   )
  )

;; --- Global Variables ---

(define-perm *local-info* local-player-info (new 'static 'local-player-info))
(define-perm *remote-info* remote-player-info (new 'static 'remote-player-info))
(define-extern *mp-puppet* target)
