  (move-to-vehicle       15)
  (board-vehicle         16)
  (ride                  17)
  (exit-vehicle          18)
  (wait-at-dest          19)
  (in-ditch              20)
  (idle                  21)
  (dormant               22)
  (notice                23)
  (hostile               24)
  (stare                 25)
  (hit                   26)
  (die                   27)
  (walk                  28)
  (run                   29)
  (talk                  30)
