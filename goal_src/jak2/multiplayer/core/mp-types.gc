;; --- Helper functions for handle resolution ---

(defun handle->process-safe ((h handle))
  (if (and (nonzero? (the-as int h))
           (!= h (the-as handle #f))
           (zero? (logand (the-as int h) 3))) ;; Pointers must be 4-byte aligned
      (handle->process h)
      (the-as process #f)
      )
  )

;; --- String Hashing Helper ---
(defun string-crc32 ((str string))
  "Simple hash function for level name verification (MEMORY BOUNDED)"
  (if (or (not str) (zero? str))
      (return (the-as uint 0)))
  (let ((hash (the-as uint 0))
        (ptr (-> str data))
        (max-len (-> str allocated-length)) ;; The physical RAM limit of the string!
        (i 0))
    ;; Loop until we hit the null terminator OR we hit the RAM limit
    (while (and (< i max-len) (nonzero? (-> ptr 0)))
      (set! hash (+ (-> ptr 0) (* hash 31)))
      (set! ptr (&-> ptr 1))
      (+! i 1))
    hash))

;; --- Type Definitions ---

(declare-type process-drawable process)
(declare-type process-focusable process-drawable)
(declare-type enemy process-focusable)
(declare-type citizen enemy)
(declare-type vehicle process-focusable)
(declare-type target process-focusable)

(deftype mp-enemy-state (structure)
  ((actor-id    uint32)
   (x           float)
   (y           float)
   (z           float)
   (quat-x     float)
   (quat-y     float)
   (quat-z     float)
   (quat-w     float)
   (pad1       float 3) ;; Removed anim-index, anim-frame, last-anim-frame
   (hp         int32)
   (state      uint32)
   (focus-aid  uint32)
   (attack-flag uint8)
   (owner       uint8)
   (is-aggro    uint8)
   (pad         uint8 5)
   (last-updated uint64)
   (pad2        uint8 8))
  :size-assert 80)

(defenum mp-scene-state (uint32)
  (none 0)
  (started 1)
  (request-skip 2)
  (skipped 3)
  )

(deftype mp-event (structure)
  ((etype uint32)
   (pad   uint8 12)
   (data  uint8 480) ;; Expansion to 496 total (16-byte aligned array)
   )
  :size-assert 496)

(deftype mp-edge-grab-event-data (structure)
  ((world-vertex               vector 8 :inline)   ;; 128
   (local-vertex               vector 8 :inline)   ;; 128
   (status                     uint64)             ;; 8
   (actor-cshape-prim-offset   int32)              ;; 4
   (actor-id                   uint32)             ;; 4 (AID or NetID)
   (actor-kind                 uint32)             ;; 4 (1=AID, 2=VehicleNetID, 3=PedestrianNetID)
   (hanging-matrix             matrix :inline)     ;; 64
   (left-hand-hold             vector :inline)     ;; 16
   (right-hand-hold            vector :inline)     ;; 16
   (center-hold-old            vector :inline)     ;; 16
   (edge-tri-pat               uint32)             ;; 4
   (found-edge-bool            uint32)             ;; 4
   (pilot-edge-grab-bool       uint32)             ;; 4
   (pilot-local-pos            vector :inline)     ;; 16
   (pilot-local-dir            vector :inline)     ;; 16
   (pilot-actor-id             uint32)             ;; 4 (AID or NetID)
   (pilot-actor-kind           uint32)             ;; 4 (1=AID, 2=VehicleNetID, 3=PedestrianNetID)
   (pilot-start-grab-pos       vector :inline)     ;; 16
   (pilot-grab-interp          float)              ;; 4
   ) ;; Total: 460 bytes (Fits in 488)
  )

(define-extern mp-vehicle-find-by-net-id (function uint vehicle))
(define-extern mp-pedestrian-find-by-net-id (function uint citizen))
(define-extern entity-by-aid (function uint entity))

