;;-*-Lisp-*-
(in-package goal)

;; --- Globals for Throttling ---
(define-perm *multi-last-send-time* time-frame 0)
(define-perm *multi-remote-spawn-time* time-frame 0)
(define-perm *mp-last-scene-player* symbol #f)
(define-extern *has-ridden-before?* symbol)
(define *multi-sync-tps* 20)

;; --- Animation Sync Tuning Globals ---
(define *mp-anim-smooth-sync?* #t)      ;; Use P-Controller for drift correction?
(define *mp-anim-gain* 0.05)            ;; How aggressively we close the frame gap (Reduced to 0.05)
(define *mp-anim-snap-threshold* 30.0) ;; Error in frames before a hard snap occurs
(define *mp-anim-latency-factor* 1.0)  ;; Multiplier for prediction (0.0 to 1.5)
(define *mp-anim-speed-lerp* 0.2)      ;; EMA smoothing factor for client-speed (0.1 to 0.5)
(define *mp-anim-speed-offset* 0.0)    ;; Constant bias added to the incoming NetV (e.g. -0.05)
(define *mp-anim-max-speed* 3.0)       ;; Maximum allowed playback speed (Reduced to 1.5)
(define *mp-anim-min-speed* 0.5)       ;; Minimum allowed playback speed
(define *mp-anim-ping-buffer* 10.0)    ;; Base ping buffer in ticks
(define *mp-anim-safety-buffer* 1.0)   ;; Targeted "lag" in frames to prevent jitter (interpolation delay)
(define *mp-anim-ticks-to-frames* 5.0) ;; Engine constant: 300 ticks / 60 fps = 5.0
(define *mp-anim-blend-time* (seconds 0.05)) ;; Time to blend between different animations
(define *mp-anim-max-latency* (seconds 0.5)) ;; Maximum time we are allowed to predict forward

(defconstant MP_EVENT_ORB (the-as uint 1))
(defconstant MP_EVENT_GEM (the-as uint 2))
(defconstant MP_EVENT_BREAK (the-as uint 3))
(defconstant MP_EVENT_ATTACK_ENEMY (the-as uint 4))
(defconstant MP_EVENT_ENEMY_DEATH (the-as uint 5))
(defconstant MP_EVENT_PLAYER_HIT (the-as uint 6))
(defconstant MP_EVENT_DEBUG (the-as uint 7))
(defconstant MP_EVENT_SCENE_START (the-as uint 8))
(defconstant MP_EVENT_SCENE_REQUEST_SKIP (the-as uint 10))
(defconstant MP_EVENT_SCENE_SKIPPED (the-as uint 11))

;; --- String Hashing Helper ---
(defun string-crc32 ((str string))
  "Simple hash function for level name verification (MEMORY BOUNDED)"
  (if (or (not str) (zero? str))
      (return (the-as uint 0)))
  (let ((hash (the-as uint 0))
        (ptr (-> str data))
        (max-len (-> str allocated-length)) ;; The physical RAM limit of the string!
        (i 0))
    ;; Loop until we hit the null terminator OR we hit the RAM limit
    (while (and (< i max-len) (nonzero? (-> ptr 0)))
      (set! hash (+ (-> ptr 0) (* hash 31)))
      (set! ptr (&-> ptr 1))
      (+! i 1))
    hash))

;; --- Types & Externs ---

(define *local-riding?* #f)
(define *mp-processing-remote-event* #f)
(define-perm *mp-last-remote-scene-active* uint (the uint 0))
(define *mp-remote-wants-skip* #f)
(define *mp-local-wants-skip* #f)

(deftype mp-enemy-state (structure)
  ((actor-id    uint32)
   (x           float)
   (y          float)
   (z          float)
   (quat-x     float)
   (quat-y     float)
   (quat-z     float)
   (quat-w     float)
   (anim-index int32)
   (anim-frame float)
   (last-anim-frame float)
   (hp         int32)
   (state      uint32)
   (focus-aid  uint32)
   (attack-flag uint8)
   (pad         uint8 7))
  )

(defenum mp-scene-state (uint32)
  (none 0)
  (started 1)
  (request-skip 2)
  (skipped 3)
  )

(deftype mp-event (structure)
  ((etype uint32)
   (pad   uint32)
   (data  uint8 40)
   )
  :size-assert 48)

(deftype mp-world-event (mp-event)
  ((aid uint32 :overlay-at (-> data 0))
   )
  )

(deftype mp-scene-event (mp-event)
  ((state      mp-scene-state :overlay-at (-> data 0))
   (scene-name uint8 32      :overlay-at (-> data 4))
   (event-id   uint32        :overlay-at (-> data 36))
   )
  )

(deftype remote-player-info (structure)
  ((x           float)
   (y           float)
   (z           float)
   (angle       float)
   (id          uint32)
   (role        int32)
   (anim        int32)
   (anim-frame  float)
   (level       uint32)
   (status      int32)
   (packet-id   uint32)
   (riding?     uint32)
   (sidekick-anim  int32)
   (sidekick-frame float)
   (clock       time-frame)
   (last-anim-frame float)
   (last-sidekick-frame float)
   (pad         uint8 8)
   )
  :size-assert 80)

(deftype local-player-info (structure)
  ((x           float)
   (y           float)
   (z          float)
   (angle       float)
   (role        int32)
   (anim        int32)
   (anim-frame  float)
   (level       uint32)
   (packet-id   uint32)
   (riding?     uint32)
   (sidekick-anim  int32)
   (sidekick-frame float)
   (clock       time-frame)
   (last-anim-frame float)
   (last-sidekick-frame float)
   (pad         uint8 4)
   ;; Global World Sync (Outgoing)
   (money       float)
   (gems        float)
   (skill       float)
   ;; Global World Sync (Incoming from Host)
   (sync-money  float)
   (sync-gems   float)
   (sync-skill  float)
   (sync-flag   uint32)
   (host-task   uint32)
   (host-node   uint32)
   (host-continue uint8 32)
   (task-mask   uint8 64)
   (sync-aids-count uint32)
   (sync-aids   uint32 128)
   ;; AI / Enemy Sync
   (enemy-count uint32)
   (pad-enemy   uint8 12)
   (enemies     mp-enemy-state 24 :inline)
   (player-procs handle 2)
   )
  :size-assert 2288)

(deftype mp-event-buffer (structure)
  ((out-count uint32)
   (out-events mp-event 16 :inline :offset 16)  ;; 16 * 48 = 768. Ends at 16 + 768 = 784
   (in-count  uint32 :offset 784)
   (in-events  mp-event 16 :inline :offset 800) ;; 16 * 48 = 768. Ends at 800 + 768 = 1568
   )
  :size-assert 1568)

;; Helper macros to access sidekick sync data
(defmacro mp-sidekick-anim ()
  `(-> *remote-info* sidekick-anim)
  )

(defmacro mp-sidekick-frame ()
  `(-> *remote-info* sidekick-frame)
  )

(defmacro set-mp-sidekick-anim! (val)
  `(set! (-> *local-info* sidekick-anim) ,val)
  )

(defmacro set-mp-sidekick-frame! (val)
  `(set! (-> *local-info* sidekick-frame) ,val)
  )


(deftype mp-reconnect-dialog (process)
  ()
  (:state-methods
    idle
    die
    )
  )

