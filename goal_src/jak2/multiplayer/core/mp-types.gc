(define-extern pc-multi-set-status (function int none))
(define-extern pc-multi-get-found-ip (function string))
(define-extern pc-multi-stop-search (function none))
(define-extern pc-multi-start-search (function none))
(define-extern pc-multi-disconnect (function none))
(define-extern mp-reconnect-dialog-init (function none :behavior mp-reconnect-dialog))
(define-extern mp-send-world-event (function uint uint none))
(define-extern mp-receive-world-event (function uint uint none))
(define-extern mp-airlock-remote-ready? (function vector symbol))
(define-extern *kernel-context* kernel-context)
(declare-type enemy process-focusable)
(define-extern iterate-process-tree (function process-tree (function object object) kernel-context object))
(define-extern mp-sync-enemies-host (function none))
(define-extern mp-sync-enemies-client (function none))
(define-extern mp-enemy-sync-idle (state enemy))

;; Queue for outbound events to prevent overwriting when multiple things happen in 1 frame
(define-perm *mp-event-queue* (inline-array mp-event) (new 'static 'inline-array mp-event 32))
(define-perm *mp-event-queue-write-ptr* int 0)
(define-perm *mp-event-queue-read-ptr* int 0)

;; Persistent globals
(define-perm *local-info* local-player-info (new 'static 'local-player-info))
(define-perm *remote-info* remote-player-info (new 'static 'remote-player-info))
(define-perm *mp-event-buffer* mp-event-buffer (new 'static 'mp-event-buffer))
(define-perm *multi-sync-enabled?* symbol #f)
(define-perm *multi-last-sync-frame* time-frame (seconds 0))
(define-perm *multi-last-in-event-seq* uint (the-as uint 0))
(define-perm *multi-remote-interp-pos* vector (new 'static 'vector))
(define-perm *multi-remote-interp-angle* float 0.0)
(define-perm *multi-remote-first-seen?* symbol #t)
(define-perm *multi-remote-render-pos* vector (new 'static 'vector))
(define-perm *multi-remote-render-quat* structure (new 'static 'structure))
(define-perm *mp-reconnect-process* handle (the-as handle #f))
(define-perm *mp-reconnect-menu-active?* symbol #f)

;; Track the manager via handle to prevent respawn loops
(declare-type mp-target-proxy process-focusable)
(deftype mp-manager (process)
  ((root                basic)
   (remote-id           uint32)
   (remote-role         int32)
   (manipy-proc         handle)
   (proxy-proc          handle)
   (spawn-timer         time-frame)
   (last-anim-packet    uint32)
   (anim-speed          float)
   (client-speed        float)
   (last-arrival-time   time-frame)

   (last-remote-clock   time-frame)

   (last-remote-frame   float)
   (last-remote-sidekick-frame float)
   )
  (:state-methods
    idle)
  )

(define-perm *mp-remote-manager* (pointer mp-manager) (the-as (pointer mp-manager) #f))
(define-perm *multi-manager-handle* handle (the-as handle #f))
(define-perm *multi-remote-spawn-time* time-frame 0)

(define *mp-nametag-string* (new 'global 'string 128 (the-as string #f)))
(define *mp-local-nametag-string* (new 'global 'string 128 (the-as string #f)))
(define *mp-scene-name-scratch* (new 'global 'string 32 (the-as string #f)))
(define *mp-continue-name* (new 'global 'string 32 (the-as string #f)))
(define-perm *mp-debug-draw* symbol #f)
(define-perm *mp-debug-simulate-loss?* symbol #f)
(define-perm *mp-debug-simulate-loss-time* time-frame 0)
(define-perm *mp-hijacks-applied?* symbol #f)
(define *mp-daxter-damage-mult* 2.0)

(defmacro mp-is-jak? ()
  "Is the local player the Host (Jak)?"
  `(= (-> *local-info* role) 0)
  )

(defmacro mp-is-daxter? ()
  "Is the local player the Client (Daxter)?"
  `(= (-> *local-info* role) 1)
  )


