;; --- Function Implementations ---

(defun mp-sidekick-anim ()
  (-> *remote-info* sidekick-anim)
  )

(defun mp-sidekick-frame ()
  (-> *remote-info* sidekick-frame)
  )

;; --- Macro Definitions ---

(defmacro set-mp-sidekick-anim! (val)
  `(set! (-> *local-info* sidekick-anim) ,val)
  )

(defmacro set-mp-sidekick-frame! (val)
  `(set! (-> *local-info* sidekick-frame) ,val)
  )

(defmacro mp-is-jak? ()
  "Is the local player the Host (Jak)?"
  `(= (-> *local-info* role) 0)
  )

(defmacro mp-is-daxter? ()
  "Is the local player the Client (Daxter)?"
  `(= (-> *local-info* role) 1)
  )

(defmacro mp-enemy-should-process-damage? (e-proc)
  "Should the local machine process damage/state changes? (Owner OR Remote Event)"
  `(or (mp-enemy-authoritative? ,e-proc) *mp-processing-remote-event*)
  )

